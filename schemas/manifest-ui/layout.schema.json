{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot.manifest-ui.layout.schema.json",
  "type": "object",
  "required": ["root"],
  "properties": {
    "root": { "$ref": "#/$defs/node" }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "name"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "scenePath": { "type": "string" },
        "properties": { "type": "object" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } }
      }
    }
  }
}
