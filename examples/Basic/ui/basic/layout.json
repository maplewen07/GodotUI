{
  "root": {
    "id": "BasicWidget",
    "type": "Control",
    "name": "BasicWidget",
    "properties": {
      "anchors_preset": 15,
      "anchor_right": 1.0,
      "anchor_bottom": 1.0,
      "grow_horizontal": 2,
      "grow_vertical": 2
    },
    "children": [
      {
        "id": "Card",
        "type": "PanelContainer",
        "name": "Card",
        "properties": {
          "anchors_preset": 8,
          "anchor_left": 0.5,
          "anchor_top": 0.5,
          "anchor_right": 0.5,
          "anchor_bottom": 0.5,
          "offset_left": -240.0,
          "offset_top": -150.0,
          "offset_right": 240.0,
          "offset_bottom": 150.0
        },
        "children": [
          {
            "id": "Content",
            "type": "VBoxContainer",
            "name": "Content",
            "properties": {
              "layout_mode": 2,
              "theme_override_constants/separation": 12
            },
            "children": [
              {
                "id": "TitleLabel",
                "type": "Label",
                "name": "TitleLabel",
                "localization": {
                  "text": "basic.title"
                }
              },
              {
                "id": "HintLabel",
                "type": "Label",
                "name": "HintLabel",
                "localization": {
                  "text": "basic.hint"
                }
              },
              {
                "id": "NameInput",
                "type": "LineEdit",
                "name": "NameInput",
                "properties": {
                  "placeholder_text": "Name"
                }
              },
              {
                "id": "GreetingLabel",
                "type": "Label",
                "name": "GreetingLabel",
                "properties": {
                  "text": ""
                }
              },
              {
                "id": "CountLabel",
                "type": "Label",
                "name": "CountLabel",
                "properties": {
                  "text": ""
                }
              },
              {
                "id": "GreetButton",
                "type": "Button",
                "name": "GreetButton",
                "localization": {
                  "text": "basic.greet"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
