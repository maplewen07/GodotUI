{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot.manifest-ui.codegen.schema.json",
  "type": "object",
  "required": ["schemaVersion", "generator"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "generator": { "type": "string" },
    "requiredServices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "property"],
        "additionalProperties": false,
        "properties": { "type": { "type": "string" }, "property": { "type": "string" }, "key": { "type": "string" } }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["channel", "action"],
        "additionalProperties": false,
        "properties": { "channel": { "type": "string" }, "action": { "enum": ["open", "close"] }, "packageId": { "type": "string" } }
      }
    }
  }
}
