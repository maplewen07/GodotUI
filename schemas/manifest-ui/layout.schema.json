{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot.manifest-ui.layout.schema.json",
  "type": "object",
  "required": ["root"],
  "additionalProperties": false,
  "properties": { "root": { "$ref": "#/$defs/node" } },
  "$defs": {
    "assetRef": {
      "type": "object",
      "required": ["assetRef"],
      "additionalProperties": false,
      "properties": { "assetRef": { "type": "string", "minLength": 1 } }
    },
    "color": {
      "type": "object",
      "required": ["color"],
      "additionalProperties": false,
      "properties": {
        "color": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 }
      }
    },
    "nodePath": {
      "type": "object",
      "required": ["nodePath"],
      "additionalProperties": false,
      "properties": { "nodePath": { "type": "string" } }
    },
    "vector2i": {
      "type": "object",
      "required": ["vector2i"],
      "additionalProperties": false,
      "properties": {
        "vector2i": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "type", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "scenePath": { "type": "string" },
        "scriptPath": { "type": "string", "pattern": "^res://.+\\.(cs|gd)$" },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
              { "$ref": "#/$defs/assetRef" },
              { "$ref": "#/$defs/color" },
              { "$ref": "#/$defs/nodePath" },
              { "$ref": "#/$defs/vector2i" }
            ]
          }
        },
        "localization": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "required": ["key"],
                "additionalProperties": false,
                "properties": {
                  "key": { "type": "string", "minLength": 1 },
                  "context": { "type": "string" },
                  "arguments": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            ]
          }
        },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } }
      }
    }
  }
}
