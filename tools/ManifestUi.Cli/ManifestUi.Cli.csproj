<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>manifest-ui</AssemblyName>
    <RootNamespace>ManifestUi.Cli</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\addons\manifest_ui\tooling\ManifestUiTool.cs" Link="Tooling\ManifestUiTool.cs" />
    <Content Include="..\..\addons\manifest_ui\tooling\schemas\*.json" Link="schemas\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
