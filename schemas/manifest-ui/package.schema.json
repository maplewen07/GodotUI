{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot.manifest-ui.package.schema.json",
  "type": "object",
  "required": ["schemaVersion", "packageId", "displayName", "designResolution", "assets", "layout", "bindings", "codegen", "validation", "godot"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packageId": { "type": "string" },
    "displayName": { "type": "string" },
    "designResolution": { "type": "array", "minItems": 2, "maxItems": 2 },
    "assets": { "type": "string" },
    "layout": { "type": "string" },
    "bindings": { "type": "string" },
    "codegen": { "type": "string" },
    "validation": { "type": "string" },
    "godot": { "type": "object" }
  }
}
